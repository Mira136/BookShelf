@model List<BookShelf.Models.CartItem>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    decimal total = ViewBag.Total ?? 0;
    var user = ViewBag.User as BookShelf.Models.ApplicationUser;
}
<title>BookShelf</title>
@section Styles {
    <link rel="stylesheet" href="~/css/checkout.css" asp-append-version="true" />
}

<div class="checkout-container">
    <div class="checkout-nav">
        <a asp-controller="Order" asp-action="Cart" class="back-icon-btn">
            <i class="fa fa-arrow-left"></i>
        </a>
    </div>

    <h2 class="checkout-title">Checkout Confirmation</h2>

    <!-- DELIVERY ADDRESS -->
    <div class="card delivery-card">
        <div class="card-header">
            <h3>Delivery Address</h3>
        </div>
        <hr />
        <p class="address-name">@user?.FullName</p>
        <p class="address-text">
            @user?.Address <br />
            @user?.PhoneNumber
        </p>
    </div>

    <!-- ORDER SUMMARY -->
    <h2 class="section-title">Order Summary</h2>
    <div class="card order-card">
        @foreach (var item in Model)
        {
            <div class="order-item">
                <img src="~/images/@(item.Book?.ImagePath ?? "book1.png")"
                     onerror="this.src='/images/book1.png'" />
                <div class="item-info">
                    <p class="item-title">@item.Book?.Title</p>
                    <span class="item-qty">@item.Quantity book</span>
                </div>
                <span class="item-price">₹@item.Book?.SellingPrice</span>
            </div>
        }
        <div class="order-total">
            <span>Total</span>
            <strong>₹@total</strong>
        </div>
    </div>

    <!-- PAYMENT METHOD -->
    <h2 class="section-title">Payment Method</h2>
    <div class="card payment-card">
        <p><strong>Payment Method:</strong> Cash on Delivery</p>
        <p class="payment-note">
            Keep <strong>₹@total</strong> at the time of delivery
        </p>
    </div>

    <div class="cod-note">
        <i class="fa fa-lock"></i>
        <span>COD order is confirmed on next step</span>
    </div>

    <!-- PLACE ORDER BUTTON -->
    <div class="checkout-action">
        <form method="post" action="/Order/PlaceOrder">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn-next">Place Order</button>
        </form>
    </div>
</div>
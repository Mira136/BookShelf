@model List<BookShelf.Models.CartItem>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    decimal total = ViewBag.Total ?? 0;
}
<title>BookShelf</title>
@section Styles {
    <link rel="stylesheet" href="~/css/cart.css" asp-append-version="true" />
}

@if (Model == null || !Model.Any())
{
    <div class="empty-cart">
        <i class="fa fa-cart-shopping empty-icon"></i>

        <h2>Your cart is empty</h2>
        <p>Looks like you haven’t added any books yet.</p>

        <a href="/Home/Index" class="btn-browse">
            Browse Books
        </a>
    </div>
}
else
{
    <div class="book-grid">
        @foreach (var item in Model)
        {
            <div class="book-card">
                <img src="~/images/@(item.Book?.ImagePath ?? "book1.png")"
                     alt="@item.Book?.Title"
                     onerror="this.src='/images/book1.png'" />
                <p class="book-title-text">@item.Book?.Title</p>
                <p class="book-sub">@item.Book?.Category?.Name</p>
                <div class="price">
                    <span class="old">₹@item.Book?.ActualPrice</span>
                    <span class="new">₹@item.Book?.SellingPrice</span>
                </div>
                <div class="card-buttons">
                    <a href="/Home/BookDetails/@item.Book?.Id" class="view-btn">View</a>
                    <a href="/Order/RemoveFromCart/@item.Id"
                       onclick="return confirm('Remove from cart?')"
                       class="delete-btn">
                        <i class="fa-regular fa-trash-can"></i>
                    </a>
                </div>
            </div>
        }
    </div>

    <div class="price-detail-card">
        <h3 class="price-detail-title">Price Detail</h3>
        <table class="price-table">
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Book?.Title</td>
                    <td>₹@item.Book?.SellingPrice</td>
                </tr>
            }
        </table>
        <div class="order-total-row">
            <span class="order-label">Order total</span>
            <span class="order-amount">₹@total</span>
        </div>
        <div class="continue-row">
            <a class="btn-continue" href="/Order/Checkout">Continue</a>
        </div>
    </div>
}
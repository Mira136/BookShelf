@model List<BookShelf.Models.WishlistItem>

@{
    ViewData["Title"] = "Wishlist";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/cart.css" asp-append-version="true" />
}

<!-- ===== WISHLIST BOOK CARDS ===== -->
<div class="book-grid">

    @foreach (var item in Model)
    {
        var book = item.Book;

        <div class="book-card">

            <img src="~/images/@book.ImagePath" alt="@book.Title" />

            <p class="book-title-text">@book.Title</p>

            <p class="book-sub">@book.Category?.Name</p>

            <div class="price">
                @if (book.ActualPrice != null)
                {
                    <span class="old">₹@book.ActualPrice</span>
                }
                <span class="new">₹@book.SellingPrice</span>
            </div>

            <div class="card-buttons">

                <a asp-controller="Home"
                   asp-action="BookDetails"
                   asp-route-id="@book.Id"
                   class="view-btn">
                    View
                </a>

                <!-- Remove from wishlist -->
                <form method="post" action="/Order/ToggleWishlist">
                    <input type="hidden" name="bookId" value="@book.Id" />

                    <button type="submit"
                            class="wishlist-btn remove-btn"
                            title="Remove from wishlist">
                        <i class="fa-solid fa-heart"></i>
                    </button>
                </form>

            </div>
        </div>
    }

</div>
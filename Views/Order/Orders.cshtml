@{
    // ViewData["Title"] = "My Orders";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<title>BookShelf</title>
@section Styles {
    <link rel="stylesheet" href="~/css/orders.css" asp-append-version="true" />
}

<div class="orders-container">

    <!-- HEADER -->
    <div class="orders-back">
        <a asp-controller="Home" asp-action="Index" class="back-icon-btn">
            <i class="fa fa-arrow-left"></i>
        </a>
        <span class="orders-page-title">My Orders</span>
    </div>
    <div class="orders-page-sub">3 orders placed</div>

    <!-- LIST -->
    <div class="orders-list">

        <!-- CARD 1 -->
        <div class="order-card">
            <div class="order-img-wrap">
                <img src="~/images/book1.png" class="order-img" alt="Maths Book" />
            </div>
            <div class="order-details">
                <h3>Mathematics Textbook - XII</h3>
                <div class="order-meta">
                    <p class="muted">
                        <i class="fa fa-hashtag"></i>
                        Order ID : <b>#BK10234</b>
                    </p>
                    <p class="muted">
                        <i class="fa fa-calendar"></i>
                        12 Feb 2026
                    </p>
                </div>
                <div class="order-divider"></div>
                <div class="order-footer">
                    <p class="total">Total : <span>₹140</span></p>
                    <span class="order-status delivered">
                        <i class="fa fa-circle-check"></i> Delivered
                    </span>
                </div>
            </div>
        </div>

        <!-- CARD 2 -->
        <div class="order-card">
            <div class="order-img-wrap">
                <img src="~/images/book8.png" class="order-img" alt="Oxford Dictionary" />
            </div>
            <div class="order-details">
                <h3>Oxford English Mini Dictionary</h3>
                <div class="order-meta">
                    <p class="muted">
                        <i class="fa fa-hashtag"></i>
                        Order ID : <b>#BK10189</b>
                    </p>
                    <p class="muted">
                        <i class="fa fa-calendar"></i>
                        05 Jan 2026
                    </p>
                </div>
                <div class="order-divider"></div>
                <div class="order-footer">
                    <p class="total">Total : <span>₹200</span></p>
                    <span class="order-status delivered">
                        <i class="fa fa-circle-check"></i> Delivered
                    </span>
                </div>
            </div>
        </div>

        <!-- CARD 3 -->
        <div class="order-card">
            <div class="order-img-wrap">
                <img src="~/images/book2.png" class="order-img" alt="AI Book" />
            </div>
            <div class="order-details">
                <h3>Artificial Intelligence</h3>
                <div class="order-meta">
                    <p class="muted">
                        <i class="fa fa-hashtag"></i>
                        Order ID : <b>#BK10074</b>
                    </p>
                    <p class="muted">
                        <i class="fa fa-calendar"></i>
                        20 Dec 2025
                    </p>
                </div>
                <div class="order-divider"></div>
                <div class="order-footer">
                    <p class="total">Total : <span>₹550</span></p>
                    <span class="order-status processing">
                        <i class="fa fa-clock"></i> Processing
                    </span>
                </div>
            </div>
        </div>

    </div>

</div>
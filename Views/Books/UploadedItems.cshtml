@{
    Layout = null;
    var books = ViewBag.Books as List<BookShelf.Models.Book> ?? new();
    var ebooks = ViewBag.Ebooks as List<BookShelf.Models.Ebook> ?? new();
}

<title>BookShelf</title>
<link rel="stylesheet" href="~/css/uploadeditems.css" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

<div class="uploaded-page">

    <a asp-controller="Account" asp-action="UserProfile" class="back-arrow">
        <i class="fa fa-arrow-left"></i>
    </a>

    <div class="sections-container">

        <!-- BOOKS -->
        <div class="items-panel">
            <h2 class="panel-title">Books (@books.Count)</h2>

            @if (books.Count == 0)
            {
                <p style="color:#999; padding:16px;">No books uploaded yet.</p>
            }

            @foreach (var book in books)
            {
                <div class="item-row">
                    <img src="~/images/@(book.ImagePath ?? "book1.png")"
                         class="book-thumb"
                         onerror="this.src='/images/book1.png'" />

                    <div class="item-info">
                        <div class="item-name">@book.Title</div>
                        <div class="item-time">
                            <b>Uploaded at :</b>
                            @book.CreatedAt.ToString("yyyy-MM-dd")
                            &nbsp;&nbsp;
                            @book.CreatedAt.ToString("HH:mm")
                        </div>
                    </div>

                    <div class="item-actions">
                        <a asp-controller="Books" asp-action="Details" asp-route-id="@book.Id" class="view-icon">
                            <i class="fa-regular fa-eye"></i>
                        </a>
                        <a href="/Books/DeleteBook/@book.Id"
                           class="delete-icon"
                           onclick="return confirm('Delete this book?')">
                            <i class="fa-regular fa-trash-can"></i>
                        </a>
                    </div>
                </div>
            }
        </div>

        <!-- EBOOKS -->
        <div class="items-panel">
            <h2 class="panel-title">Ebooks (@ebooks.Count)</h2>

            @if (ebooks.Count == 0)
            {
                <p style="color:#999; padding:16px;">No ebooks uploaded yet.</p>
            }

            @foreach (var ebook in ebooks)
            {
                <div class="item-row">
                    <div class="ebook-pdf-icon">
                        <i class="fa-regular fa-file-pdf"></i>
                    </div>

                    <div class="item-info">
                        <div class="item-name">@ebook.Title</div>
                        <div class="item-time">
                            <b>Uploaded at :</b>
                            @ebook.CreatedAt.ToString("yyyy-MM-dd")
                            &nbsp;&nbsp;
                            @ebook.CreatedAt.ToString("HH:mm")
                        </div>
                    </div>

                    <div class="item-actions">
                        <a href="/EBooks/EbookDetails/@ebook.Id" class="view-icon">
                            <i class="fa-regular fa-eye"></i>
                        </a>
                        <a href="/Books/DeleteEbook/@ebook.Id"
                           class="delete-icon"
                           onclick="return confirm('Delete this ebook?')">
                            <i class="fa-regular fa-trash-can"></i>
                        </a>
                    </div>
                </div>
            }
        </div>

    </div>
</div>
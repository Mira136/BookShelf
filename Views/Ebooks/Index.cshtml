@model List<BookShelf.Models.Ebook>
@{
    // ViewData["Title"] = "E-Books";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BookShelf</title>

    @* Font Awesome for icons *@
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
    @* Your CSS *@
    <link rel="stylesheet" href="@Url.Content("~/css/ebooks.css")" />
</head>
<body>


    <!-- ══════════════════ MAIN ══════════════════ -->
    <div class="main-container">


        <!-- ── CONTENT ────────────────────────────── -->
        <main class="content">

            <div class="page-header">
                <a asp-controller="Home"
                   asp-action="Index"
                   class="back-btn">
                    <i class="fa fa-arrow-left"></i>
                </a>

                <h1 class="page-title">E-books</h1>
            </div>
            <!-- Search Bar -->
            <div class="ebook-search-wrapper">
                <div class="ebook-search-box">
                    <input type="text" placeholder="Search E-book here" id="ebookSearch" />
                    <i class="fa fa-search search-icon"></i>
                </div>
            </div>

            <!-- Ebook List -->
            <div class="ebook-list" id="ebookList">

                @foreach (var item in Model)
                {
                    <div class="ebook-card">

                        <div class="ebook-pdf-icon">
                            <i class="fa-regular fa-file-pdf"></i>
                        </div>

                        <div class="ebook-info">
                            <div class="ebook-title">
                                @item.Title | @item.Author |
                                @(item.Category != null ? item.Category.Name : "No Category") |
                                @item.Language
                            </div>

                            <div class="ebook-meta">
                                Uploaded by : <strong>@item.Uploader?.UserName</strong>
                            </div>
                        </div>

                        <div class="ebook-actions">

                            <!-- DOWNLOAD -->
                            <a asp-controller="Ebooks"
                               asp-action="Download"
                               asp-route-id="@item.Id"
                               class="btn-download">
                                <i class="fa fa-download"></i>
                            </a>

                            <!-- READ -->
                            <a asp-controller="Ebooks"
                               asp-action="EbookDetails"
                               asp-route-id="@item.Id"
                               class="btn-read">
                                <i class="fa fa-book-open"></i>
                            </a>

                        </div>
                    </div>
                }

            </div>
            @* end #ebookList *@

        </main>
    </div>

    <!-- ══════════════════ SEARCH SCRIPT ══════════════════ -->
    <script>
        document.getElementById('ebookSearch').addEventListener('keyup', function () {
            const query = this.value.toLowerCase();
            document.querySelectorAll('.ebook-card').forEach(function (card) {
                const text = card.querySelector('.ebook-title').textContent.toLowerCase();
                card.style.display = text.includes(query) ? '' : 'none';
            });
        });
    </script>

</body>
</html>

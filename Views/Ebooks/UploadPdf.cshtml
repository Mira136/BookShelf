@model BookShelf.Models.Ebook

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BookShelf</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/upload-pdf.css" />
</head>
<body>

<div class="upload-pdf-page">

    <!-- HEADER -->
    <div class="page-header">
        <a href="/Home/Index" class="btn-back">
            <i class="fa fa-arrow-left"></i>
        </a>
        <h1 class="page-title">Upload PDF</h1>
    </div>

    <!-- ✅ FORM -->
    <form asp-action="UploadPdf" method="post" enctype="multipart/form-data">

    <div class="upload-card">

        <!-- DROPZONE -->
        <div class="dropzone" id="dropzone" onclick="document.getElementById('pdfInput').click()">
            <div class="dropzone-icon">
                <i class="fa-solid fa-cloud-arrow-up"></i>
            </div>
            <div class="dropzone-title">Choose a file or drag & drop it here</div>
            <div class="dropzone-subtitle">File must be in PDF format</div>

            <button class="btn-browse" type="button" id="browseBtn">
                <i class="fa fa-folder-open"></i> Browse File
            </button>

            <!-- IMPORTANT -->
            <input type="file" id="pdfInput" name="pdfFile" accept=".pdf,application/pdf" />
        </div>

        <!-- BOOK INFO -->
        <div class="book-info-panel">
            <div class="book-info-grid">

                <!-- Title -->
                <div class="field-group-wrap">
                    <div class="field-row">
                        <label class="field-row-label">Book Title</label>
                        <input id="bookTitle" name="Title" class="field-row-input" type="text" />
                    </div>
                    <div class="field-error" id="err-bookTitle">Book title is required.</div>
                </div>

                <!-- Language -->
                <div class="field-group-wrap">
                    <div class="field-row">
                        <label class="field-row-label">Language</label>
                        <div class="select-wrap">
                            <select id="language" name="Language" class="field-row-select">
                                <option value="" disabled selected>Select</option>
                                <option value="english">English</option>
                                <option value="hindi">Hindi</option>
                                <option value="gujarati">Gujarati</option>
                                <option value="marathi">Marathi</option>
                                <option value="tamil">Tamil</option>
                                <option value="telugu">Telugu</option>
                                <option value="other">Other</option>
                            </select>
                        </div>
                    </div>
                    <div class="field-error" id="err-language">Please select a language.</div>
                </div>

                <!-- Author -->
                <div class="field-group-wrap">
                    <div class="field-row">
                        <label class="field-row-label">Author</label>
                        <input id="author" name="Author" class="field-row-input" type="text" />
                    </div>
                    <div class="field-error" id="err-author">Author name is required.</div>
                </div>

                <!-- Name -->
                <div class="field-group-wrap">
                    <div class="field-row">
                        <label class="field-row-label">Your Name</label>
                        <input id="uploaderName" name="UploaderName" class="field-row-input" type="text" />
                    </div>
                    <div class="field-error" id="err-uploaderName">Your name is required.</div>
                </div>

                <!-- Category -->
                <div class="field-group-wrap">
                    <div class="field-row">
                        <label class="field-row-label">Category</label>
                        <div class="select-wrap">
                                    <select id="category" name="CategoryId" required class="field-row-select">
                                        <option value="">-- Select Category --</option>

                                        @foreach (var cat in (List<Category>)ViewBag.Categories)
                                        {
                                            <option value="@cat.Id">@cat.Name</option>
                                        }
                                    </select>
                        </div>
                    </div>
                    <div class="field-error" id="err-category">Please select a category.</div>
                </div>

                <!-- Email -->
                <div class="field-group-wrap">
                    <div class="field-row">
                        <label class="field-row-label">Email</label>
                        <input id="email" name="Email" class="field-row-input" type="email" />
                    </div>
                    <div class="field-error" id="err-email">Enter a valid email address.</div>
                </div>

            </div>
        </div>

        <!-- FILE PREVIEW -->
        <div class="file-preview-bar" id="filePreviewBar">
            <div class="file-pdf-icon"></div>
            <div class="file-preview-info">
                <div class="file-preview-name" id="fileName">file.pdf</div>
                <div class="file-preview-progress">
                    <div class="file-preview-progress-fill" id="progressFill"></div>
                </div>
            </div>
            <button class="file-preview-remove" type="button" onclick="removeFile()">
                <i class="fa fa-circle-xmark"></i>
            </button>
        </div>

        <!-- SUBMIT -->
        <div class="submit-area">
            <button class="btn-submit" id="submitBtn" type="button" onclick="handleSubmit()">
                Submit
            </button>

            <div class="success-msg" id="successMsg">
                Uploaded Successfully!!
            </div>
        </div>

    </div>

    </form>
</div>

<!-- ✅ SCRIPT -->
<script>
    var selectedFile = null;
    var dropzone = document.getElementById('dropzone');

    document.getElementById('browseBtn').addEventListener('click', function(evt) {
        evt.stopPropagation();
        document.getElementById('pdfInput').click();
    });

    dropzone.addEventListener('dragover', function(e) {
        e.preventDefault();
        dropzone.classList.add('dragover');
    });

    dropzone.addEventListener('dragleave', function(e) {
        if (!dropzone.contains(e.relatedTarget)) 
            dropzone.classList.remove('dragover');
    });

    dropzone.addEventListener('drop', function(e) {
        e.preventDefault();
        dropzone.classList.remove('dragover');
        if (e.dataTransfer.files.length > 0)
            processFile(e.dataTransfer.files[0]);
    });

    document.getElementById('pdfInput').addEventListener('change', function() {
        if (this.files.length > 0)
            processFile(this.files[0]);
    });

    function processFile(file) {
        var name = file.name;
        var isPdf = file.type === 'application/pdf' || name.toLowerCase().endsWith('.pdf');

        if (!isPdf) {
            dropzone.classList.add('shake');
            setTimeout(() => dropzone.classList.remove('shake'), 400);
            return;
        }

        selectedFile = file;
        document.getElementById('fileName').textContent = name;
        document.getElementById('filePreviewBar').classList.add('visible');

        setTimeout(() => {
            document.getElementById('progressFill').style.width = '100%';
        }, 80);
    }

    function removeFile() {
        selectedFile = null;
        document.getElementById('pdfInput').value = '';
        document.getElementById('filePreviewBar').classList.remove('visible');
        document.getElementById('progressFill').style.width = '0%';
    }

    function isNotEmpty(v) { return v.length > 0; }

    function isValidEmail(v) {
        var atPos = v.indexOf('@@');
        if (atPos < 1) return false;

        var domain = v.substring(atPos + 1);
        var dotPos = domain.lastIndexOf('.');
        return dotPos > 0 && dotPos < domain.length - 1;
    }

    var rules = {
        bookTitle:    { fn: isNotEmpty },
        author:       { fn: isNotEmpty },
        uploaderName: { fn: isNotEmpty },
        language:     { fn: isNotEmpty },
        category:     { fn: isNotEmpty },
        email:        { fn: isValidEmail }
    };

    function validateField(id) {
        var el  = document.getElementById(id);
        var err = document.getElementById('err-' + id);
        var val = el.value.trim();
        var valid = rules[id].fn(val);

        el.classList.toggle('error', !valid);

        if (err) {
            valid ? err.classList.remove('visible') : err.classList.add('visible');
        }

        return valid;
    }

    var fieldIds = ['bookTitle', 'author', 'uploaderName', 'language', 'category', 'email'];

    fieldIds.forEach(function(id) {
        var el = document.getElementById(id);
        var evt = (el.tagName === 'SELECT') ? 'change' : 'blur';

        el.addEventListener(evt, function() {
            validateField(id);
        });
    });

    function handleSubmit() {
        var allValid = true;

        fieldIds.forEach(function(id) {
            if (!validateField(id)) allValid = false;
        });

        if (!selectedFile) {
            allValid = false;
            dropzone.classList.add('shake');
            setTimeout(() => dropzone.classList.remove('shake'), 400);
        }

        if (!allValid) return;

        const dt = new DataTransfer();
        dt.items.add(selectedFile);
        document.getElementById('pdfInput').files = dt.files;

        document.getElementById('submitBtn').disabled = true;
        document.getElementById('successMsg').classList.add('visible');

        setTimeout(() => {
            document.querySelector('form').submit();
        }, 1000);
    }
</script>

</body>
</html>
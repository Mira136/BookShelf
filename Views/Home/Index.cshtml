@model List<BookShelf.Models.Book>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="book-grid">

    @foreach (var book in Model)
    {
        <div class="book-card">

            <!-- IMAGE -->
            <img src="@(string.IsNullOrEmpty(book.ImagePath) ? "/images/default.png" : "/images/" + book.ImagePath)" />

            <!-- TITLE -->
            <h3>@book.Title</h3>

            <!-- CATEGORY -->
            <p>
                @(book.Category != null ? book.Category.Name : "General")
            </p>

            <!-- PRICE -->
            <div class="price">
                @if (book.ActualPrice != null)
                {
                    <span class="old">₹@book.ActualPrice</span>
                }
                <span class="new">₹@book.SellingPrice</span>
            </div>

            <!-- BUTTONS -->
            <div class="card-buttons">

                <!-- VIEW BUTTON (SAME STYLE) -->
                <a asp-controller="Home"
                   asp-action="BookDetails"
                   asp-route-id="@book.Id"
                   class="view-btn">
                    View
                </a>

                <!-- WISHLIST -->
                @if (User.Identity.IsAuthenticated)
                {
                    <form method="post" action="/Order/ToggleWishlist">
                        <input type="hidden" name="bookId" value="@book.Id" />

                        <button type="submit" class="wishlist-btn">
                            <i class="fa @(book.IsInWishlist ? "fa-solid" : "fa-regular") fa-heart"></i>
                        </button>
                    </form>
                }
                else
                {
                    <button class="wishlist-btn"
                            onclick="window.location.href='/Account/Login'">
                        <i class="fa-regular fa-heart"></i>
                    </button>
                }

            </div>

        </div>
    }

</div>
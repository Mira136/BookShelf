@model BookShelf.Models.Book

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<title>BookShelf</title>

@section Styles {
    <link rel="stylesheet" href="~/css/book-details.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/uploader-info.css" />
}

<div class="book-details-container">

    <!-- TOP BAR -->
    <div class="top-bar">
        <button class="btn-back"
                onclick="location.href='@Url.Action("Index", "Home")'">
            <i class="fa fa-arrow-left"></i>
        </button>
    </div>

    <!-- MAIN -->
    <div class="book-details">

        <!-- LEFT -->
        <div class="book-image">

            @if (!string.IsNullOrEmpty(Model.ImagePath))
            {
                <img class="main-img" src="~/images/@Model.ImagePath" />
            }
            else
            {
                <img class="main-img" src="~/images/book1.png" />
            }

            <div class="btn-row">
                @if (User.Identity.IsAuthenticated)
                {
                    <a class="btn-main" href="/Order/AddToCart/@Model.Id">
                        <i class="fa fa-shopping-cart"></i>
                        Add to cart
                    </a>
                }
                else
                {
                    <button class="btn-main" onclick="window.location.href='/Account/Login'">
                        <i class="fa fa-shopping-cart"></i>
                        Add to cart
                    </button>
                }

                @if (User.Identity.IsAuthenticated)
                {
                    <a class="btn-main" href="/Order/AddToCart/@Model.Id?buyNow=true">
    <i class="fa-solid fa-sack-dollar"></i>
    Buy now
</a>
                }
                else
                {
                    <button class="btn-main" onclick="window.location.href='/Account/Login'">
                        <i class="fa-solid fa-sack-dollar"></i>
                        Buy now
                    </button>
                }
            </div>

            @if (User.Identity.IsAuthenticated)
            {
                <button class="uploader-btn"
                        onclick="location.href='@Url.Action("UploaderInfo", "Home", new { id = Model.Id })'">
                    <i class="fa fa-circle-user"></i>
                    Uploader Info
                </button>
            }
            else
            {
                <button class="uploader-btn" onclick="window.location.href='/Account/Login'">
                    <i class="fa fa-circle-user"></i>
                    Uploader Info
                </button>
            }

        </div>

        <!-- RIGHT -->
        <div class="book-info">

            <div class="book-title">
                @Model.Title
            </div>

            <!-- PRICE -->
            <div class="price-section">
                <div>
                    <span class="actual-label">Actual Price</span>
                    <div style="display:flex; align-items:baseline; gap:12px;">
                        <span class="price-main">₹@Model.ActualPrice</span>
                        <span class="price-old">₹@Model.SellingPrice</span>
                        
                    </div>
                </div>
                @{
                    var save = Model.SellingPrice - (Model.ActualPrice ?? 0) ;
                }
                <span class="price-save">🎉 Save ₹@save</span>
            </div>

            <!-- INFO -->
            <div class="info-rows-wrapper">

                <div class="info-row">
                    <span class="label">Availability :</span>
                    <span class="stock">
                        @(Model.IsAvailable ? "In stock" : "Out of stock")
                    </span>
                </div>

                <div class="info-row">
                    <span class="label">Condition :</span>
                    <span>@Model.Condition</span>
                </div>

                <div class="info-row">
                    <span class="label">Author :</span>
                    <span>@Model.Author</span>
                </div>

                <div class="info-row">
                    <span class="label">Category :</span>
                    <span>@Model.Category?.Name</span>
                </div>

                <div class="info-row">
                    <span class="label">Language :</span>
                    <span>@Model.Language</span>
                </div>

                <div class="info-row">
                    <span class="label">Education Level :</span>
                    <span>@Model.EducationLevel</span>
                </div>

                <div class="info-row">
                    <span class="label">Description :</span>
                    <span>@Model.Description</span>
                </div>

                <!-- RATING -->
                <div class="rating">
                    <span class="label">Rating :</span>

                    @{
                        int fullStars = (int)Math.Round(Model.Rating);
                    }

                    @for (int i = 0; i < fullStars; i++)
                    {
                        <i class="fa fa-star"></i>
                    }
                </div>

            </div>
        </div>
    </div>

    <!-- DIVIDER -->
    <div class="section-divider"></div>

    <!-- REVIEWS (Optional dynamic later) -->
    <div class="review-section">
        <div class="review-header">
            <div class="review-title">Customer Reviews</div>
            <span class="review-count">@Model.Reviews.Count reviews</span>
        </div>
        <div class="review-form-box">
            @if (User.Identity.IsAuthenticated)
            {
                <form method="post" action="/Home/AddReview" class="review-form">

                    <input type="hidden" name="BookId" value="@Model.Id" />

                    <!-- Stars -->
                    <div class="star-rating">
                        <input type="radio" name="Rating" value="5" id="star5"><label for="star5">★</label>
                        <input type="radio" name="Rating" value="4" id="star4"><label for="star4">★</label>
                        <input type="radio" name="Rating" value="3" id="star3"><label for="star3">★</label>
                        <input type="radio" name="Rating" value="2" id="star2"><label for="star2">★</label>
                        <input type="radio" name="Rating" value="1" id="star1"><label for="star1">★</label>
                    </div>

                    <textarea name="Comment" placeholder="Share your thoughts about this book..." required></textarea>

                    <button type="submit">Submit Review</button>

                </form>
            }
            else
            {
                <p class="login-msg">
                    <i class="fa fa-lock"></i>
                    Please <a href="/Account/Login">login</a> to write a review
                </p>
            }
        </div>
        @foreach (var review in Model.Reviews)
        {
            <div class="review-item">
                <img src="/images/profile_image.png" class="profile-img">
                <div class="review-text">
                    <span class="reviewer-name">@(review.User?.UserName ?? "Anonymous")</span>
                    <span class="reviewer-comment">@review.Comment</span>
                </div>
            </div>
        }

    </div>

    @if (Model == null)
    {
        <div>Book not found.</div>
          return;
      }
</div>
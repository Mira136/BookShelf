@{
    bool isLoggedIn = true;   // 🔴 change true/false to test

    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

    Func<string, string, string> isActive = (controller, action) =>
    {
        return currentController == controller && currentAction == action ? "active" : "";
    };
}

<!DOCTYPE html>
<html>
<head>
    <title>BookShelf</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <link rel="stylesheet" href="~/css/site.css" />

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>

<body>

    <!-- ================= HEADER ================= -->
    <div class="header">

        <div class="header-left">
            <img src="~/images/logo.png" class="logo-img" />
            <span>BookShelf</span>
        </div>

        <div class="header-right">

            <div class="search-box">
                <input type="text" placeholder="Search books..." />
                <i class="fa fa-search"></i>
            </div>

            @if (isLoggedIn)
            {
                <i class="fa fa-bell header-icon"></i>
                <i class="fa fa-user header-icon"></i>
            }
            else
            {
                <a href="/Account/Login" class="header-link">Login</a>
                <a href="/Account/Register" class="header-link">Sign up</a>
            }

        </div>
    </div>

    <!-- ================= MAIN ================= -->
    <div class="main-container">

        <!-- ========== SIDEBAR ========== -->
        <div class="sidebar">
            <ul>

                <!-- DASHBOARD -->
                <li class="@isActive("Home", "Index")">
                    <a href="/Home/Index">
                        <i class="fa fa-home"></i>
                        <span>Dashboard</span>
                    </a>
                </li>

                <!-- CATEGORY -->
                <li class="@isActive("Home", "Category")">
                    <a href="/Home/Category">
                        <i class="fa fa-th-large"></i>
                        <span>Category</span>
                    </a>
                </li>


                @if (isLoggedIn)
                {
                    <!-- ===== LOGGED IN MENU ===== -->

                    <li>
                        <a href="#">
                            <i class="fa fa-cart-shopping"></i>
                            <span>Cart</span>
                        </a>
                    </li>

                    <li>
                        <a href="#">
                            <i class="fa fa-heart"></i>
                            <span>Wishlist</span>
                        </a>
                    </li>

                    <li>
                        <a href="#">
                            <i class="fa fa-box"></i>
                            <span>My Orders</span>
                        </a>
                    </li>

                    <li>
                        <a href="#">
                            <i class="fa fa-upload"></i>
                            <span>Upload PDF</span>
                        </a>
                    </li>

                    <li>
                        <a href="#">
                            <i class="fa fa-book-open"></i>
                            <span>Upload Book</span>
                        </a>
                    </li>

                    <!-- 🔥 FIXED HERE -->
                    <li class="@isActive("Home", "Ebooks")">
                        <a href="/Home/Ebooks">
                            <!-- FIX: was href="Ebooks" -->
                            <i class="fa fa-book"></i>
                            <span>E-Books</span>
                        </a>
                    </li>

                    <li>
                        <a href="#">
                            <i class="fa fa-info-circle"></i>
                            <span>About</span>
                        </a>
                    </li>

                    <li>
                        <a href="#">
                            <i class="fa fa-right-from-bracket"></i>
                            <span>Logout</span>
                        </a>
                    </li>
                }
                else
                {
                    <!-- ===== GUEST MENU -->

                    <li>
                        <a href="/Account/Login">
                            <i class="fa fa-cart-shopping"></i>
                            <span>Cart</span>
                        </a>
                    </li>

                    <li>
                        <a href="/Account/Login">
                            <i class="fa fa-heart"></i>
                            <span>Wishlist</span>
                        </a>
                    </li>

                    <li>
                        <a href="/Account/Login">
                            <i class="fa fa-upload"></i>
                            <span>Upload PDF</span>
                        </a>
                    </li>

                    <li>
                        <a href="/Account/Login">
                            <i class="fa fa-book-open"></i>
                            <span>Upload Book</span>
                        </a>
                    </li>

                    <li>
                        <a asp-controller="Home" asp-action="Ebooks">
                            <i class="fa fa-book"></i>
                            <span>E-Books</span>
                        </a>
                    </li>

                    <li>
                        <a href="#">
                            <i class="fa fa-info-circle"></i>
                            <span>About</span>
                        </a>
                    </li>
                }

            </ul>
        </div>

        <!-- ========== PAGE CONTENT ========== -->
        <div class="content">
            @RenderBody()
        </div>

    </div>

</body>
</html>
@{
    bool isLoggedIn = true;   // 🔴 CHANGE THIS: true = logged in, false = guest
}

<!DOCTYPE html>
<html>
<head>
    <title>BookShelf</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@500;600&family=Nunito:wght@600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" />

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>

<body>

    <!-- HEADER FULL WIDTH -->
    <div class="header">

        <div class="header-left">
            <img src="~/images/logo.png" class="logo-img" />
            <span>BookShelf</span>
        </div>

        <div class="header-right">

            <div class="search-box">
                <input type="text" placeholder="Search books..." />
                <i class="fa fa-search"></i>
            </div>

            @if (isLoggedIn)
            {
                <!-- AFTER LOGIN -->
                <i class="fa fa-bell header-icon"></i>
                <i class="fa fa-user header-icon"></i>
            }
            else
            {
                <!-- BEFORE LOGIN -->
                <a href="/Account/Login" style="color:#7b2f2f;font-weight:600;text-decoration:none;">Login</a>
                <a href="/Account/Register" style="color:#7b2f2f;font-weight:600;text-decoration:none;">Sign up</a>
            }

        </div>

    </div>

    <div class="main-container">

        <!-- SIDEBAR -->
        <div class="sidebar">
            <ul>
                <li class="active"><i class="fa fa-home"></i><span>Dashboard</span></li>
                <li><i class="fa fa-th-large"></i><span>Category</span></li>

                @if (isLoggedIn)
                {
                    <li><i class="fa fa-cart-shopping"></i><span>Cart</span></li>
                    <li><i class="fa fa-heart"></i><span>Wishlist</span></li>
                    <li><i class="fa fa-box"></i><span>My Orders</span></li>
                    <li><i class="fa fa-upload"></i><span>Upload PDF</span></li>
                    <li><i class="fa fa-book-open"></i><span>Upload Book</span></li>
                    <li><i class="fa fa-book"></i><span>E-Books</span></li>
                    <li><i class="fa fa-info-circle"></i><span>About</span></li>
                    <li><i class="fa fa-right-from-bracket"></i><span>Logout</span></li>
                }
                else
                {
                    <!-- REDIRECT TO LOGIN -->
                    <li><a href="/Account/Login"><i class="fa fa-cart-shopping"></i><span>Cart</span></a></li>
                    <li><a href="/Account/Login"><i class="fa fa-heart"></i><span>Wishlist</span></a></li>
                    <li><a href="/Account/Login"><i class="fa fa-upload"></i><span>Upload PDF</span></a></li>
                    <li><a href="/Account/Login"><i class="fa fa-book-open"></i><span>Upload Book</span></a></li>
                    <li><a href="/Account/Login"><i class="fa fa-book"></i><span>E-Books</span></a></li>
                    <li><i class="fa fa-info-circle"></i><span>About</span></li>
                }
            </ul>
        </div>

        <!-- CONTENT -->
        <div class="content">
            @RenderBody()
        </div>

    </div>

</body>
</html>
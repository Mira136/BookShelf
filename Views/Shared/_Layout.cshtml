@{
    bool isLoggedIn = User.Identity != null && User.Identity.IsAuthenticated;
    bool isAdmin = User.IsInRole("Admin");

    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

    bool isAdminPage = currentController == "Admin";

    Func<string, string, string> isActive = (controller, action) =>
    {
        return currentController == controller && currentAction == action ? "active" : "";
    };

    // Helper function for guest links: redirects to login if not logged in
    string GuestOrUserLink(string controller, string action)
    {
        return isLoggedIn ? Url.Action(action, controller) : Url.Action("Login", "Account");
    }
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BookShelf</title>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/register.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/forgotpassword.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/notification.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/userprofile.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/EditUserProfile.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/aboutus.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/AdminProfile.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin-aboutus.css" asp-append-version="true" />

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

    @RenderSection("Styles", required: false)
</head>

<body>
    <!-- ================= HEADER ================= -->
    <div class="header">
        <div class="header-left">
            <img src="~/images/logo.png" class="logo-img" />
            <span>BookShelf</span>
        </div>

        <div class="header-right">
            <div class="search-box">
                <input type="text" id="globalBookSearch" placeholder="Search books..." />
                <i class="fa fa-search"></i>
            </div>

            @if (isLoggedIn)
            {
                <a asp-controller="Account" asp-action="Notifications" class="header-icon">
                    <i class="fa fa-bell"></i>
                </a>

                @if (isAdmin)
                {
                    <a asp-controller="Account" asp-action="AdminProfile">
                        <i class="fa fa-user header-icon"></i>
                    </a>
                }
                else
                {
                    <a asp-controller="Account" asp-action="UserProfile">
                        <i class="fa fa-user header-icon"></i>
                    </a>
                }
            }
            else
            {
                <a asp-controller="Account" asp-action="Login" class="header-link">Login</a>
                <a asp-controller="Account" asp-action="Register" class="header-link">Sign up</a>
            }
        </div>
    </div>

    <div class="main-container">

        @* ================= USER SIDEBAR ================= *@
        @if (!isAdminPage)
        {
            <div class="sidebar">
                <ul>

                    <!-- Dashboard -->
                    <li class="@isActive("Home", "Index")">
                        <a asp-controller="Home" asp-action="Index">
                            <i class="fa fa-home"></i>
                            <span>Dashboard</span>
                        </a>
                    </li>

                    <!-- Category -->
                    <li class="@isActive("Home", "Category")">
                        <a asp-controller="Home" asp-action="Category">
                            <i class="fa fa-th-large"></i>
                            <span>Category</span>
                        </a>
                    </li>

                    <!-- Cart -->
                    <li class="@isActive("Order", "Cart")">
                        <a href="@GuestOrUserLink("Order", "Cart")">
                            <i class="fa fa-cart-shopping"></i>
                            <span>Cart</span>
                        </a>
                    </li>

                    <!-- Wishlist -->
                    <li class="@isActive("Order", "Wishlist")">
                        <a href="@GuestOrUserLink("Order", "Wishlist")">
                            <i class="fa fa-heart"></i>
                            <span>Wishlist</span>
                        </a>
                    </li>

                    <!-- My Orders (only for logged-in users) -->
                    @if (isLoggedIn)
                    {
                        <li class="@isActive("Order", "Orders")">
                            <a asp-controller="Order" asp-action="Orders">
                                <i class="fa fa-box"></i>
                                <span>My Orders</span>
                            </a>
                        </li>
                    }

                    <!-- Upload PDF -->
                    <li class="@isActive("Ebooks", "UploadPdf")">
                        <a href="@GuestOrUserLink("Ebooks", "UploadPdf")">
                            <i class="fa fa-upload"></i>
                            <span>Upload PDF</span>
                        </a>
                    </li>

                    <!-- Upload Book -->
                    <li class="@isActive("Books", "UploadBook")">
                        <a href="@GuestOrUserLink("Books", "UploadBook")">
                            <i class="fa fa-book-open"></i>
                            <span>Upload Book</span>
                        </a>
                    </li>

                    <!-- E-Books -->
                    <li class="@isActive("Ebooks", "Index")">
                        <a href="@GuestOrUserLink("Ebooks", "Index")">
                            <i class="fa fa-book"></i>
                            <span>E-Books</span>
                        </a>
                    </li>

                    <!-- About Us -->
                    <li class="@isActive("Account", "About")">
                        <a asp-controller="Account" asp-action="About">
                            <i class="fa fa-circle-info"></i>
                            <span>About Us</span>
                        </a>
                    </li>

                    <!-- Logout only for logged-in users -->
                    @if (isLoggedIn)
                    {
                        <!-- Logout only for logged-in users -->
                        @if (isLoggedIn)
                        {
                            <li>
                                <a href="#" id="logout-link">
                                    <i class="fa fa-right-from-bracket"></i>
                                    <span>Logout</span>
                                </a>
                                <form id="logout-form" asp-controller="Account" asp-action="Logout" method="post" style="display:none;"></form>
                            </li>
                        }
                    }
                </ul>
            </div>
        }

        

        <div class="content">
            @RenderBody()
        </div>

    </div>

    @await RenderSectionAsync("Scripts", required: false)

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const searchInput = document.getElementById("globalBookSearch");
            if (!searchInput) return;

            searchInput.addEventListener("keyup", function () {
                const query = this.value.toLowerCase();
                const cards = document.querySelectorAll(".book-card");

                cards.forEach(card => {
                    const title = card.querySelector("h3")?.innerText.toLowerCase() || "";
                    const category = card.querySelector("p")?.innerText.toLowerCase() || "";

                    card.style.display =
                        title.includes(query) || category.includes(query)
                            ? ""
                            : "none";
                });
            });
        });
    </script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var logoutLink = document.getElementById("logout-link");
            var logoutForm = document.getElementById("logout-form");

            if (logoutLink && logoutForm) {
                logoutLink.addEventListener("click", function (e) {
                    e.preventDefault();
                    logoutForm.submit();
                });
            }
        });
    </script>

</body>
</html>
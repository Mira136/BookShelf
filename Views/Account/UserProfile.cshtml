@model BookShelf.Models.ViewModels.UserProfileViewModel
@{
    Layout = null;
}
<title>BookShelf – Profile</title>
<link rel="stylesheet" href="~/css/userprofile.css" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

<div class="profile-page">

    <a asp-controller="Home" asp-action="Index" class="back-arrow" title="Go back">
        <i class="fa fa-arrow-left"></i>
    </a>

    <div class="page-header">
        <h2 class="profile-heading">Profile</h2>
    </div>

    <div class="profile-card">

        <!-- LEFT — avatar -->
        <div class="card-left">
            <div class="avatar-wrapper" title="Photo">
                <img src="~/images/@(Model.ProfileImage ?? "reg_profile.png")"
                     id="profilePreview" class="avatar-img" alt="Profile Photo" />
            </div>
        </div>

        <!-- RIGHT — fields + actions -->
        <div class="card-right">

            <div class="panel-top-row">
                <a asp-controller="Account" asp-action="EditUserProfile" class="edit-link">
                    <i class="fa-solid fa-pen"></i>
                    <span>Edit Profile</span>
                </a>
            </div>

            <div class="fields-group">

                <div class="field">
                    <label>Name</label>
                    <div class="field-box">@Model.Name</div>
                </div>

                <div class="field">
                    <label>Username</label>
                    <div class="field-box">@Model.Username</div>
                </div>

                <div class="field">
                    <label>Number</label>
                    <div class="field-box">@Model.Number</div>
                </div>

                <div class="card-divider"></div>

                <!-- Credit — no ₹ symbol -->
                <div class="field">
                    <label>Credit</label>
                    <div class="field-box credit-box">
                        @Model.Credit
                        <i class="fa-solid fa-lock credit-lock" title="Managed by BookShelf"></i>
                    </div>
                </div>

            </div>

            <a asp-controller="Account" asp-action="Logout" class="logout-btn">
                <i class="fa-solid fa-right-from-bracket"></i>
                Logout
            </a>

        </div>
    </div>
</div>

@model BookShelf.Models.ViewModels.LoginViewModel
@{
    Layout = null;
}
<title>BookShelf</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&family=Caveat:wght@700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="~/css/auth.css" />
<script>document.documentElement.classList.add('page-login'); document.body.classList.add('page-login');</script>

<!-- interactive background canvas -->
<canvas id="bg-canvas"></canvas>

<div class="page-wrap">
    <div class="login-card">

        <!-- ═══ LEFT PANEL ═══ -->
        <div class="left-panel">

            <div class="brand">BookShelf</div>

            <div class="welcome-block">
                <h1 class="welcome-title">Welcome Back</h1>
                <p class="welcome-sub">Sign in to continue to BookShelf</p>
            </div>

            <form asp-action="Login" method="post" novalidate class="login-form" id="loginForm">

                <!-- EMAIL -->
                <div class="field-group">
                    <label asp-for="Email" class="f-label">Email</label>
                    <input asp-for="Email"
                           id="emailInput"
                           class="f-input"
                           type="email"
                           placeholder="example@email.com"
                           autocomplete="email" />
                    <span asp-validation-for="Email" class="f-error" id="emailError"></span>
                </div>

                <!-- PASSWORD -->
                <div class="field-group">
                    <label asp-for="Password" class="f-label">Password</label>
                    <div class="pw-wrap">
                        <input asp-for="Password"
                               id="pwInput"
                               class="f-input"
                               type="password"
                               placeholder="Enter your password"
                               autocomplete="current-password" />
                        <button type="button" class="pw-toggle" id="pwToggle" onclick="togglePw()" tabindex="-1" aria-label="Toggle password visibility">
                            <!-- eye open -->
                            <svg id="eyeOpen" xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7-1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                            </svg>
                            <!-- eye off (hidden by default) -->
                            <svg id="eyeOff" xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="display:none">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.477 0-8.268-2.943-9.542-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.477 0 8.268 2.943 9.542 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" />
                            </svg>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="f-error" id="pwError"></span>
                </div>

                <!-- REMEMBER + FORGOT -->
                <div class="extras-row">
                    <label class="remember-wrap">
                        <input asp-for="RememberMe" type="checkbox" class="chk" />
                        <span class="chk-text">Remember me</span>
                    </label>
                    <a asp-controller="Account" asp-action="ForgotPassword" class="forgot-link">Forgot password?</a>
                </div>

                <!-- LOGIN BUTTON -->
                <button type="submit" class="btn-login" id="loginBtn">
                    <span id="btnText">Login</span>
                    <span id="btnLoader" class="btn-loader" style="display:none">
                        <span class="dot"></span><span class="dot"></span><span class="dot"></span>
                    </span>
                </button>

                <!-- DIVIDER -->
                <div class="divider"><span>OR</span></div>

                <!-- GUEST -->
                <a asp-controller="Home" asp-action="Index" class="btn-guest">Explore As Guest</a>

                <!-- SIGN UP -->
                <p class="signup-row">
                    Don't have an account?
                    <a asp-controller="Account" asp-action="Register" class="signup-link">Sign Up</a>
                </p>

            </form>
        </div>
        <!-- ═══ END LEFT ═══ -->
        <!-- ═══ RIGHT PANEL ═══ -->
        <div class="right-panel">
            <img class="right-img" src="~/images/login.png" alt="BookShelf illustration" />
        </div>
        <!-- ═══ END RIGHT ═══ -->

        <button type="submit" class="login-button">
            Login
        </button>

        <div class="signup-text">
            Don’t have account ?
            <a asp-controller="Account" asp-action="Register"
               class="signup-link">
                Sign Up
            </a>
        </div>
    </div>
</div>

<script>
    /* password toggle */
    function togglePw() {
        var inp = document.getElementById('pwInput');
        var open = document.getElementById('eyeOpen');
        var off  = document.getElementById('eyeOff');
        if (inp.type === 'password') {
            inp.type = 'text';
            open.style.display = 'none';
            off.style.display  = 'block';
        } else {
            inp.type = 'password';
            open.style.display = 'block';
            off.style.display  = 'none';
        }
    }

    /* loading state on submit */
    document.getElementById('loginForm').addEventListener('submit', function () {
        document.getElementById('btnText').style.display   = 'none';
        document.getElementById('btnLoader').style.display = 'flex';
        document.getElementById('loginBtn').disabled = true;
    });

    /* focus error-clear */
    document.getElementById('emailInput').addEventListener('focus', function () {
        document.getElementById('emailError').textContent = '';
        this.classList.remove('f-input--error');
    });
    document.getElementById('pwInput').addEventListener('focus', function () {
        document.getElementById('pwError').textContent = '';
        this.classList.remove('f-input--error');
    });

    /* ── STATIC CORNER/EDGE ROUNDED RECTANGLE BACKGROUND ─────── */
    (function () {
        var canvas = document.getElementById('bg-canvas');
        var ctx    = canvas.getContext('2d');
        var W, H;

        function resize() {
            W = canvas.width  = window.innerWidth;
            H = canvas.height = window.innerHeight;
            draw();
        }

        /* draw a rounded rectangle centered at cx,cy rotated by angle */
        function rRect(cx, cy, w, h, r, angle) {
            ctx.save();
            ctx.translate(cx, cy);
            ctx.rotate(angle);
            ctx.beginPath();
            var hw = w / 2, hh = h / 2;
            ctx.moveTo(-hw + r, -hh);
            ctx.lineTo( hw - r, -hh);
            ctx.quadraticCurveTo( hw, -hh,  hw, -hh + r);
            ctx.lineTo( hw,  hh - r);
            ctx.quadraticCurveTo( hw,  hh,  hw - r,  hh);
            ctx.lineTo(-hw + r,  hh);
            ctx.quadraticCurveTo(-hw,  hh, -hw,  hh - r);
            ctx.lineTo(-hw, -hh + r);
            ctx.quadraticCurveTo(-hw, -hh, -hw + r, -hh);
            ctx.closePath();
            ctx.restore();
        }

        function filledRect(cx, cy, w, h, r, angle, color) {
            rRect(cx, cy, w, h, r, angle);
            ctx.fillStyle   = color;
            ctx.fill();
            ctx.strokeStyle = 'rgba(255,255,255,0.07)';
            ctx.lineWidth   = 1;
            ctx.stroke();
        }

        function outlineRect(cx, cy, w, h, r, angle, color) {
            rRect(cx, cy, w, h, r, angle);
            ctx.strokeStyle = color;
            ctx.lineWidth   = 1.2;
            ctx.stroke();
        }

        function draw() {
            /* ── base gradient ── */
            var grd = ctx.createLinearGradient(0, 0, W, H);
            grd.addColorStop(0, '#7a2e2e');
            grd.addColorStop(1, '#4a1515');
            ctx.fillStyle = grd;
            ctx.fillRect(0, 0, W, H);

            var s = Math.min(W, H);   /* scale factor */

            /* ══ SHAPES — placed in corners & edges only ══
               Each group = 2–3 overlapping rects like the reference */

            /* TOP-LEFT corner */
            filledRect( -s*0.08,  -s*0.06,  s*0.52, s*0.40, 38, -0.38, 'rgba(150,55,55,0.60)');
            filledRect( -s*0.02,   s*0.04,  s*0.44, s*0.36, 34,  -0.28, 'rgba(185,80,70,0.40)');
            outlineRect(-s*0.04,   s*0.00,  s*0.48, s*0.38, 36,  -0.32, 'rgba(255,255,255,0.10)');

            /* TOP-RIGHT corner */
            filledRect( W+s*0.08, -s*0.06,  s*0.52, s*0.40, 38,  0.38, 'rgba(140,48,48,0.58)');
            filledRect( W+s*0.02,  s*0.04,  s*0.44, s*0.36, 34,  0.28, 'rgba(175,75,65,0.38)');
            outlineRect(W+s*0.04,  s*0.00,  s*0.48, s*0.38, 36,  0.32, 'rgba(255,255,255,0.09)');

            /* BOTTOM-LEFT corner */
            filledRect( -s*0.08, H+s*0.06,  s*0.52, s*0.40, 38,  0.38, 'rgba(145,52,52,0.58)');
            filledRect( -s*0.02, H-s*0.04,  s*0.44, s*0.36, 34,  0.28, 'rgba(180,78,68,0.38)');
            outlineRect(-s*0.04, H-s*0.01,  s*0.48, s*0.38, 36,  0.32, 'rgba(255,255,255,0.09)');

            /* BOTTOM-RIGHT corner */
            filledRect( W+s*0.08, H+s*0.06, s*0.52, s*0.40, 38, -0.38, 'rgba(155,58,58,0.60)');
            filledRect( W+s*0.02, H-s*0.04, s*0.44, s*0.36, 34, -0.28, 'rgba(190,82,72,0.40)');
            outlineRect(W+s*0.04, H-s*0.01, s*0.48, s*0.38, 36, -0.32, 'rgba(255,255,255,0.10)');

            /* TOP CENTRE edge */
            filledRect( W*0.50,  -s*0.12,   s*0.42, s*0.32, 32,  0.05, 'rgba(160,62,62,0.45)');
            outlineRect(W*0.50,  -s*0.08,   s*0.46, s*0.34, 34,  0.05, 'rgba(255,255,255,0.08)');

            /* BOTTOM CENTRE edge */
            filledRect( W*0.50, H+s*0.12,   s*0.42, s*0.32, 32, -0.05, 'rgba(155,58,58,0.45)');
            outlineRect(W*0.50, H+s*0.08,   s*0.46, s*0.34, 34, -0.05, 'rgba(255,255,255,0.08)');

            /* LEFT CENTRE edge */
            filledRect( -s*0.14, H*0.50,    s*0.36, s*0.44, 36,  0.55, 'rgba(148,54,54,0.50)');
            outlineRect(-s*0.10, H*0.50,    s*0.38, s*0.46, 36,  0.55, 'rgba(255,255,255,0.08)');

            /* RIGHT CENTRE edge */
            filledRect( W+s*0.14, H*0.50,   s*0.36, s*0.44, 36, -0.55, 'rgba(148,54,54,0.50)');
            outlineRect(W+s*0.10, H*0.50,   s*0.38, s*0.46, 36, -0.55, 'rgba(255,255,255,0.08)');
        }

        window.addEventListener('resize', resize);
        resize();
    })();
</script>
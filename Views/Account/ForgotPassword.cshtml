@model BookShelf.Models.ViewModels.ForgotPasswordViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Forgot Password - BookShelf</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&family=Caveat:wght@700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/forgotpassword.css" />
</head>
<body class="page-forgot">

    <canvas id="bg-canvas"></canvas>

    <div class="page-wrap">
        <div class="fp-card">

            <!-- LEFT PANEL: form -->
            <div class="panel-left">

                <div class="brand">BookShelf</div>

                <div class="welcome-block">
                    <h1 class="welcome-title">Forgot Password?</h1>
                    <p class="welcome-sub">No worries — we'll help you get back in.</p>
                </div>

                <!-- step 1: email form (shown by default) -->
                <div id="step-email">
                    <form asp-action="ForgotPassword" method="post" novalidate id="fpForm" class="fp-form">
                        @Html.AntiForgeryToken()

                        <div class="field-group">
                            <label class="f-label">Email Address</label>
                            <div class="input-icon-wrap">
                                <svg class="input-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                                </svg>
                                <input asp-for="Email"
                                       id="emailInput"
                                       class="f-input"
                                       type="email"
                                       placeholder="Enter your registered email"
                                       autocomplete="email" />
                            </div>
                            <span asp-validation-for="Email" class="f-error" id="emailError"></span>
                        </div>

                        <button type="submit" class="btn-primary" id="fpBtn">
                            <span id="fpBtnText">Send Reset Link</span>
                            <span id="fpBtnLoader" class="btn-loader" style="display:none">
                                <span class="dot"></span><span class="dot"></span><span class="dot"></span>
                            </span>
                        </button>

                    </form>

                    @* Show this block if the server returned a success TempData *@
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="success-banner" id="successBanner">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                            <span>@TempData["SuccessMessage"]</span>
                        </div>
                    }

                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="error-banner">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                            <span>@TempData["ErrorMessage"]</span>
                        </div>
                    }

                    <div class="hint-row">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        <span>Check your inbox (and spam folder) after submitting.</span>
                    </div>
                </div>

                <div class="divider"><span>OR</span></div>

                <a asp-controller="Account" asp-action="Login" class="btn-back">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
                    </svg>
                    Back to Sign In
                </a>

                <p class="signup-row">
                    Don't have an account?
                    <a asp-controller="Account" asp-action="Register" class="signup-link">Sign Up</a>
                </p>

            </div>
            <!-- end panel-left -->
            <!-- RIGHT PANEL: illustration -->
            <div class="panel-right">
                <img src="~/images/forgot_passwordd.png" class="right-img" alt="Forgot password illustration" />
            </div>

        </div>
    </div>

    <script>
        /* clear error on focus */
        document.getElementById('emailInput').addEventListener('focus', function () {
            document.getElementById('emailError').textContent = '';
            this.classList.remove('f-input--error');
        });

        /* loading state on submit */
        document.getElementById('fpForm').addEventListener('submit', function () {
            document.getElementById('fpBtnText').style.display = 'none';
            document.getElementById('fpBtnLoader').style.display = 'flex';
            document.getElementById('fpBtn').disabled = true;
        });

        /* BACKGROUND CANVAS — identical to login */
        (function () {
            var canvas = document.getElementById('bg-canvas');
            var ctx = canvas.getContext('2d');
            var W, H;
            function resize() { W = canvas.width = window.innerWidth; H = canvas.height = window.innerHeight; draw(); }
            function rRect(cx,cy,w,h,r,a) {
                ctx.save(); ctx.translate(cx,cy); ctx.rotate(a); ctx.beginPath();
                var hw=w/2,hh=h/2;
                ctx.moveTo(-hw+r,-hh); ctx.lineTo(hw-r,-hh); ctx.quadraticCurveTo(hw,-hh,hw,-hh+r);
                ctx.lineTo(hw,hh-r); ctx.quadraticCurveTo(hw,hh,hw-r,hh);
                ctx.lineTo(-hw+r,hh); ctx.quadraticCurveTo(-hw,hh,-hw,hh-r);
                ctx.lineTo(-hw,-hh+r); ctx.quadraticCurveTo(-hw,-hh,-hw+r,-hh);
                ctx.closePath(); ctx.restore();
            }
            function F(cx,cy,w,h,r,a,c){rRect(cx,cy,w,h,r,a);ctx.fillStyle=c;ctx.fill();ctx.strokeStyle='rgba(255,255,255,0.07)';ctx.lineWidth=1;ctx.stroke();}
            function O(cx,cy,w,h,r,a,c){rRect(cx,cy,w,h,r,a);ctx.strokeStyle=c;ctx.lineWidth=1.2;ctx.stroke();}
            function draw() {
                var g=ctx.createLinearGradient(0,0,W,H); g.addColorStop(0,'#7a2e2e'); g.addColorStop(1,'#4a1515');
                ctx.fillStyle=g; ctx.fillRect(0,0,W,H);
                var s=Math.min(W,H);
                F(-s*.08,-s*.06,s*.52,s*.40,38,-0.38,'rgba(150,55,55,0.60)'); F(-s*.02,s*.04,s*.44,s*.36,34,-0.28,'rgba(185,80,70,0.40)'); O(-s*.04,s*.00,s*.48,s*.38,36,-0.32,'rgba(255,255,255,0.10)');
                F(W+s*.08,-s*.06,s*.52,s*.40,38,0.38,'rgba(140,48,48,0.58)'); F(W+s*.02,s*.04,s*.44,s*.36,34,0.28,'rgba(175,75,65,0.38)'); O(W+s*.04,s*.00,s*.48,s*.38,36,0.32,'rgba(255,255,255,0.09)');
                F(-s*.08,H+s*.06,s*.52,s*.40,38,0.38,'rgba(145,52,52,0.58)'); F(-s*.02,H-s*.04,s*.44,s*.36,34,0.28,'rgba(180,78,68,0.38)'); O(-s*.04,H-s*.01,s*.48,s*.38,36,0.32,'rgba(255,255,255,0.09)');
                F(W+s*.08,H+s*.06,s*.52,s*.40,38,-0.38,'rgba(155,58,58,0.60)'); F(W+s*.02,H-s*.04,s*.44,s*.36,34,-0.28,'rgba(190,82,72,0.40)'); O(W+s*.04,H-s*.01,s*.48,s*.38,36,-0.32,'rgba(255,255,255,0.10)');
                F(W*.50,-s*.12,s*.42,s*.32,32,0.05,'rgba(160,62,62,0.45)'); O(W*.50,-s*.08,s*.46,s*.34,34,0.05,'rgba(255,255,255,0.08)');
                F(W*.50,H+s*.12,s*.42,s*.32,32,-0.05,'rgba(155,58,58,0.45)'); O(W*.50,H+s*.08,s*.46,s*.34,34,-0.05,'rgba(255,255,255,0.08)');
                F(-s*.14,H*.50,s*.36,s*.44,36,0.55,'rgba(148,54,54,0.50)'); O(-s*.10,H*.50,s*.38,s*.46,36,0.55,'rgba(255,255,255,0.08)');
                F(W+s*.14,H*.50,s*.36,s*.44,36,-0.55,'rgba(148,54,54,0.50)'); O(W+s*.10,H*.50,s*.38,s*.46,36,-0.55,'rgba(255,255,255,0.08)');
            }
            window.addEventListener('resize', resize); resize();
        })();
    </script>

</body>
</html>

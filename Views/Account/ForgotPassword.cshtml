@model BookShelf.Models.ViewModels.ForgotPasswordViewModel
@{
    Layout = null;
}

<link rel="stylesheet" href="~/css/forgotpassword.css" />

<div class="forgot-page">

    <div class="left-section">

        <div class="heading-block">
            <h1 class="title">Forgot Password</h1>
            <p class="subtitle">“We’ll help you get back in.”</p>
        </div>

        <div class="card-box">
            <form asp-action="ForgotPassword" method="post">

                <label>Email address</label>

                <input asp-for="Email"
                       placeholder="Enter your registered email Id" />

                <span asp-validation-for="Email" class="validation"></span>

                <button type="submit" class="reset-btn">
                    Reset password
                </button>

            </form>
        </div>

        <div class="info-text">
            <p>Check your email for password reset instructions.</p>
            <p class="second-line">Still didn’t get mail, Try Again....</p>
        </div>

    </div>

    <div class="right-section">
        <img src="~/images/forgot_password.png" />
    </div>

</div>
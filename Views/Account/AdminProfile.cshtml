@model BookShelf.Models.ViewModels.AdminProfileViewModel
@{
    Layout = null;
}

<title>BookShelf</title>

<link rel="stylesheet" href="~/css/userprofile.css" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

<div class="profile-page">

    <!-- Back Button -->
    <a asp-controller="Admin" asp-action="Dashboard" class="back-arrow" title="Go back">
        <i class="fa fa-arrow-left"></i>
    </a>

    <div class="page-header">
        <h2 class="profile-heading">Profile</h2>
    </div>

    <div class="profile-card">

        <!-- LEFT SIDE (Profile Image) -->
        <div class="card-left">
            <div class="avatar-wrapper">
                <img src="~/images/@(Model.ProfileImage ?? "reg_profile.png")"
                     class="avatar-img"
                     alt="Profile Photo" />
            </div>
        </div>

        <!-- RIGHT SIDE -->
        <div class="card-right">

            <div class="fields-group">

                <div class="field">
                    <label>Name</label>
                    <div class="field-box">@Model.Name</div>
                </div>

                <div class="field">
                    <label>Username</label>
                    <div class="field-box">@Model.Username</div>
                </div>

                <div class="field">
                    <label>Number</label>
                    <div class="field-box">9999999999</div>
                </div>

            </div>

            <div class="profile-actions">

                <form asp-controller="Account" asp-action="Logout" method="post">
                    <button type="submit" class="logout-btn">
                        <i class="fa-solid fa-right-from-bracket"></i>
                        Logout
                    </button>
                </form>

            </div>

        </div>
    </div>
</div>
@model BookShelf.Models.ViewModels.AboutViewModel
@{
    ViewData["Title"] = "About Us";
    Layout = null;
}

<link rel="stylesheet" href="~/css/aboutus.css" />

<div class="about-page">

    <!-- HERO -->
    <div class="about-hero">
        <a asp-controller="Home" asp-action="Index" class="back-arrow">
            <img src="~/images/Back_Arrow_icon.png" />
        </a>

        <h1>About Our BookShelf</h1>
        <p>Your Trusted Place to Discover and buy books online.</p>

        <a asp-controller="Books" asp-action="Index" class="browse-btn">
            Browse Books
        </a>
    </div>

    <!-- OUR STORY -->
    <section class="section">
        <h2 class="story-heading">Our Story</h2>

        <p class="story-text">
            Our bookstore was created for people who want to
            <strong>buy and sell books at affordable prices</strong>.
            We built this platform to help users easily find new and second-hand books from home.
            Anyone can sell their books at a <strong>nominal price</strong>,
            making books more <strong>accessible</strong> and
            <strong>budget-friendly</strong> for everyone.
        </p>
    </section>

    <!-- MISSION & VISION -->
    <div class="mission-vision">
        <div class="mv-card">
            <h3>Our Mission</h3>
            <div class="card-line"></div>
            <p>
    “To <strong>provide</strong> quality books at 
    <strong>affordable</strong> prices and deliver them 
    <strong>quickly</strong> to readers.”
</p>
        </div>

        <div class="mv-card">
            <h3>Our Vision</h3>
            <div class="card-line"></div>
            <p>
                “To become a trusted online bookstore for readers everywhere.”
            </p>
        </div>
    </div>

    <!-- WHAT WE OFFER -->
    <section class="section center">

        <div class="section-title">
            <span>What We Offer</span>
        </div>

        <div class="offer-grid">
            <div class="offer-card">
                <img src="~/images/about1.png" />
                <h4>Wide Selection</h4>
            </div>

            <div class="offer-card">
                <img src="~/images/about2.png" />
                <h4>Easy Online Ordering</h4>
            </div>

            <div class="offer-card">
                <img src="~/images/about3.png" />
                <h4>Nominal Price</h4>
            </div>
        </div>
    </section>

    <!-- WHY CHOOSE US -->
    <section class="section">

        <div class="section-title">
            <span>Why Choose Us ?</span>
        </div>

        <ul class="why-list">
            <li>Trusted Online Bookstore</li>
            <li>Affordable Prices</li>
            <li>Simple Shopping Experience</li>
            <li>Great Customer Support</li>
        </ul>
    </section>

    <!-- TEAM -->
    <section class="section center">

        <div class="section-title">
            <span>The Team</span>
        </div>

        <div class="team-grid">
            <div class="team-card">
                <img src="~/images/aboutprofile.png" class="profile-img" />
                <h4>Tanvi</h4>
                <p>tanvi123@gmail.com</p>
            </div>

            <div class="team-card">
                <img src="~/images/aboutprofile.png" class="profile-img" />
                <h4>Ayushi</h4>
                <p>ayushi123@gmail.com</p>
            </div>

            <div class="team-card">
                <img src="~/images/aboutprofile.png" class="profile-img" />
                <h4>Mirali</h4>
                <p>mira123@gmail.com</p>
            </div>
        </div>
    </section>

    <!-- EMAIL BUTTON -->
    <div class="email-btn">
        Email Us If You Have Any Queries
    </div>

    <!-- FOOTER -->
    <footer class="about-footer">
        <div class="footer-left">
            © 2026 BookShelf. All rights reserved.
        </div>

        <div class="footer-icons">
            <img src="~/images/instagram.png" />
            <img src="~/images/facebook.png" />
            <img src="~/images/twitter.png" />
            <img src="~/images/Subtract.png" />
        </div>
    </footer>

</div>
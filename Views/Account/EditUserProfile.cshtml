@model BookShelf.Models.ViewModels.EditUserProfileViewModel
@{
    Layout = null;
}
<title>BookShelf – Edit Profile</title>
<link rel="stylesheet" href="~/css/userprofile.css" />
<link rel="stylesheet" href="~/css/EditUserProfile.css" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

<div class="profile-page">

    <a asp-controller="Account" asp-action="UserProfile" class="back-arrow" title="Go back">
        <i class="fa fa-arrow-left"></i>
    </a>

    <div class="page-header">
        <h2 class="profile-heading">Edit Profile</h2>
    </div>

    <div class="profile-card">

        <form asp-action="EditUserProfile" method="post" enctype="multipart/form-data" style="display:contents;">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="ExistingPhotoPath" />
            <input type="hidden" asp-for="Credit" />

            <!-- LEFT — avatar -->
            <div class="card-left">
                <div class="avatar-wrapper" onclick="document.getElementById('profileInput').click()" title="Change photo">
                    <img src="~/images/@(Model.ExistingPhotoPath ?? "reg_profile.png")"
                         id="profilePreview" class="avatar-img" alt="Profile Photo" />
                    <input type="file" id="profileInput" name="Photo" accept="image/*"
                           style="display:none;" onchange="previewPhoto(this)" />
                    <button type="button" class="camera-btn" tabindex="-1" aria-hidden="true">
                        <i class="fa-solid fa-camera"></i>
                        <span>Change Photo</span>
                    </button>
                </div>
            </div>

            <!-- RIGHT — fields -->
            <div class="card-right">

                <div class="panel-top-row">
                    <!-- Cancel button top-right -->
                    <a asp-controller="Account" asp-action="UserProfile" class="edit-link ep-cancel-btn">
                        <i class="fa-solid fa-xmark"></i>
                        <span>Cancel</span>
                    </a>
                </div>

                <div class="fields-group">

                    <div class="field">
                        <label>Name</label>
                        <div class="input-wrapper">
                            <input asp-for="Name" class="field-box ep-input" id="nameField" readonly />
                            <button type="button" class="ep-edit-btn" onclick="enableField('nameField')" title="Edit">
                                <i class="fa-solid fa-pen"></i>
                            </button>
                        </div>
                    </div>

                    <div class="field">
                        <label>Number</label>
                        <div class="input-wrapper">
                            <input asp-for="Number" class="field-box ep-input" id="numberField" readonly
                                   inputmode="numeric" maxlength="10"
                                   oninput="this.value=this.value.replace(/\D/g,'').slice(0,10)" />
                            <button type="button" class="ep-edit-btn" onclick="enableField('numberField')" title="Edit">
                                <i class="fa-solid fa-pen"></i>
                            </button>
                        </div>
                    </div>

                    <div class="card-divider"></div>

                    <!-- Credit — no ₹ symbol -->
                    <div class="field">
                        <label>Credit</label>
                        <div class="field-box credit-box">
                            @Model.Credit
                            <i class="fa-solid fa-lock credit-lock" title="Managed by BookShelf"></i>
                        </div>
                    </div>

                </div>

                <!-- Save Changes button bottom -->
                <button type="submit" class="logout-btn ep-save-btn">
                    <i class="fa-solid fa-floppy-disk"></i>
                    Save Changes
                </button>

            </div>

        </form>
    </div>

</div>

<script>
    function enableField(id) {
        var el = document.getElementById(id);
        el.removeAttribute('readonly');
        el.classList.add('ep-input--active');
        el.focus();
        var val = el.value;
        el.value = '';
        el.value = val;
    }

    function previewPhoto(input) {
        const file = input.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = function (ev) {
                document.getElementById('profilePreview').src = ev.target.result;
            };
            reader.readAsDataURL(file);
        }
    }
</script>

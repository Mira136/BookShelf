@model List<BookShelf.Models.ApplicationUser>

@{
    // ViewData["Title"] = "Users";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<title>BookShelf</title>
@section Styles {
    <link rel="stylesheet" href="~/css/users.css" />
}

<div class="users-page">

    <!-- BACK BUTTON + TITLE -->
    <div class="page-header">
        <a href="/Admin/Dashboard" class="back-btn">
            <i class="fa fa-arrow-left"></i>
        </a>
        <h2 class="page-title">Users</h2>
    </div>

    <!-- USERS CARD -->
    <div class="users-card">

        <!-- SEARCH BAR -->
        <div class="search-bar-wrapper">
            <div class="search-bar">
                <input type="text" placeholder="Search here" id="userSearch" />
                <i class="fa fa-magnifying-glass"></i>
            </div>
        </div>

        <!-- TABLE -->
        <div class="users-table">

            <!-- HEADER -->
            <div class="table-row table-header">
                <div>Sr No.</div>
                <div>Picture</div>
                <div>Name</div>
                <div>Username</div>
                <div>Number</div>
                <div>Status</div>
                <div>DateTime</div>
            </div>

            @{
                int count = 1;
            }

            @foreach (var user in Model)
            {
                <div class="table-row">
                    <div>@count</div>

                    <!-- Picture -->
                    <div>
                        <span class="avatar-icon">
                            <i class="fa fa-circle-user"></i>
                        </span>
                    </div>

                    <!-- Name -->
                    <div>@(user.UserName ?? "N/A")</div>

                    <!-- Username -->
                    <div>@user.Email</div>

                    <!-- Number -->
                    <div>@(user.PhoneNumber ?? "N/A")</div>

                    <!-- Status -->
                    <div>
                        <span class="status active">Active</span>
                    </div>

                    <!-- DateTime -->
                    <div class="datetime-cell">
                        <span class="datetime-date">
                            @user.CreatedAt.ToString("yyyy-MM-dd")
                        </span>
                        <span class="datetime-time">
                            @user.CreatedAt.ToString("HH:mm:ss")
                        </span>
                    </div>
                </div>

                count++;
            }
            
        </div>
        <!-- end users-table -->

    </div>
    <!-- end users-card -->

</div>

@section Scripts {
    <script>
        document.getElementById('userSearch').addEventListener('input', function () {
            const query = this.value.toLowerCase();
            document.querySelectorAll('.table-row:not(.table-header)').forEach(row => {
                row.style.display = row.textContent.toLowerCase().includes(query) ? '' : 'none';
            });
        });
    </script>
}
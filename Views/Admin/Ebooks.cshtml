@model List<BookShelf.Models.Ebook>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<title>BookShelf</title>

@section Styles {
    <link rel="stylesheet" href="~/css/admin-ebooks.css" />
}

<div class="adminebooks-page">

    <!-- HEADER -->
    <div class="page-header">
        <a href="/Admin/Dashboard" class="back-btn">
            <i class="fa fa-arrow-left"></i>
        </a>
        <h2 class="page-title">Ebooks</h2>
    </div>

    <div class="adminebooks-card">

        <!-- SEARCH -->
        <div class="search-bar-wrapper">
            <div class="search-bar">
                <input type="text" placeholder="Search here" id="ebookSearch" />
                <i class="fa fa-magnifying-glass"></i>
            </div>
        </div>

        <!-- TABLE -->
        <div class="adminebooks-table-wrapper">
            <div class="adminebooks-table">

                <!-- HEADER -->
                <div class="table-row table-header">
                    <div>Sr No.</div>
                    <div>Book Title</div>
                    <div>Author</div>
                    <div>Category</div>
                    <div>Language</div>
                    <div>Username</div>
                    <div>Email</div>
                    <div>DateTime</div>
                </div>

                <!-- DATA ROWS -->
                @{
                    int i = 1;
                }

                @foreach (var item in Model)
                {
                    <div class="table-row">

                        <div>@i</div>

                        <div>@item.Title</div>

                        <div>@item.Author</div>

                        <div>
                            @item.Category?.Name
                        </div>

                        <div>
                            @item.Language
                        </div>

                        <div>
                            @item.Uploader?.UserName
                        </div>

                        <div class="email-cell">
                            @item.Email
                        </div>

                        <div class="datetime-cell">
                            <span class="datetime-date">
                                @item.CreatedAt.ToString("yyyy-MM-dd")
                            </span>
                            <span class="datetime-time">
                                @item.CreatedAt.ToString("HH:mm:ss")
                            </span>
                        </div>

                    </div>

                    i++;
                }

            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('ebookSearch').addEventListener('input', function () {
            const query = this.value.toLowerCase();
            document.querySelectorAll('.table-row:not(.table-header)').forEach(row => {
                row.style.display = row.textContent.toLowerCase().includes(query) ? '' : 'none';
            });
        });
    </script>
}

@model List<BookShelf.Models.Book>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<title>BookShelf</title>

@section Styles {
    <link rel="stylesheet" href="~/css/admin-books.css" />
}

<div class="adminbooks-page">

    <!-- HEADER -->
    <div class="page-header">
        <a href="/Admin/Dashboard" class="back-btn">
            <i class="fa fa-arrow-left"></i>
        </a>
        <h2 class="page-title">Books</h2>
    </div>

    <div class="adminbooks-card">

        <!-- SEARCH -->
        <div class="search-bar-wrapper">
            <div class="search-bar">
                <input type="text" placeholder="Search here" id="bookSearch" />
                <i class="fa fa-magnifying-glass"></i>
            </div>
        </div>

        <!-- TABLE -->
        <div class="adminbooks-table-wrapper">
            <div class="adminbooks-table">

                <!-- HEADER -->
                <div class="table-row table-header">
                    <div>Sr No.</div>
                    <div>Book</div>
                    <div>Title</div>
                    <div>Author</div>
                    <div>Category</div>
                    <div>Lang.</div>
                    <div>M.R.P</div>
                    <div>S.P</div>
                    <div>Username</div>
                    <div>Email</div>
                    <div>Desc.</div>
                    <div>DateTime</div>
                </div>

                @{
                    int sr = 1;
                }

                @foreach (var book in Model)
                {
                    <div class="table-row">
                        <div>@sr</div>

                        <div>
                            @if (!string.IsNullOrEmpty(book.ImagePath))
                            {
                                <img src="~/images/@book.ImagePath" width="40" />
                            }
                            else
                            {
                                <span class="avatar-icon">
                                    <i class="fa fa-circle-user"></i>
                                </span>
                            }
                        </div>

                        <div>@book.Title</div>
                        <div>@book.Author</div>
                        <div>@book.Category?.Name</div>
                        <div>@book.Language</div>

                        <div>
                            <span class="price-sp">₹@book.SellingPrice</span>
                        </div>

                        <div>
                            <span class="price-mrp">₹@book.ActualPrice</span>
                        </div>

                        <div>@book.Uploader?.UserName</div>

                        <div>
                            @book.Uploader?.Email
                        </div>

                        <div class="desc-cell">
                            @book.Description
                        </div>

                        <div class="datetime-cell">
                            <span class="datetime-date">
                                @book.CreatedAt.ToString("yyyy-MM-dd")
                            </span>
                            <span class="datetime-time">
                                @book.CreatedAt.ToString("HH:mm:ss")
                            </span>
                        </div>
                    </div>

                    sr++;
                }

            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('bookSearch').addEventListener('input', function () {
            const query = this.value.toLowerCase();
            document.querySelectorAll('.table-row:not(.table-header)').forEach(row => {
                row.style.display = row.textContent.toLowerCase().includes(query) ? '' : 'none';
            });
        });
    </script>
}
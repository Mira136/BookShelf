@{
    // ViewData["Title"] = "Admin Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<title>BookShelf</title>

@section Styles {
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
}

<div class="admin-content">

    <!-- ===== STATS SECTION ===== -->
    <div class="admin-stats">

        <div class="admin-stat">
            <div class="stat-icon-wrap stat-icon-books">
                <i class="fa fa-book"></i>
            </div>
            <div class="stat-info">
                <span class="stat-label">Total Books</span>
                <h3>@ViewBag.TotalBooks</h3>
            </div>
        </div>

        <div class="admin-stat">
            <div class="stat-icon-wrap stat-icon-users">
                <i class="fa fa-users"></i>
            </div>
            <div class="stat-info">
                <span class="stat-label">Total Users</span>
                <h3>@ViewBag.TotalUsers</h3>
            </div>
        </div>

        <div class="admin-stat">
            <div class="stat-icon-wrap stat-icon-ebooks">
                <i class="fa fa-tablet-screen-button"></i>
            </div>
            <div class="stat-info">
                <span class="stat-label">Total E-Books</span>
                <h3>@ViewBag.TotalEbooks</h3>
            </div>
        </div>

    </div>

    <!-- ===== SECTION LABEL ===== -->
    <div class="admin-section-label">
        Quick Access
    </div>

    <!-- ===== QUICK ACCESS CARDS ===== -->
    <div class="admin-cards">

        <a asp-controller="Admin" asp-action="Books" class="admin-card-link">
            <div class="admin-card">
                <img src="~/images/admin_book.png" alt="Books" />
                <p>Books</p>
            </div>
        </a>

        <a asp-controller="Admin" asp-action="Ebooks" class="admin-card-link">
            <div class="admin-card">
                <img src="~/images/admin_ebook.png" alt="E-Books" />
                <p>E-Books</p>
            </div>
        </a>

        <a asp-controller="Admin" asp-action="Users" class="admin-card-link">
            <div class="admin-card">
                <img src="~/images/admin_users.png" alt="Users" />
                <p>Users</p>
            </div>
        </a>

        <a asp-controller="Admin" asp-action="Scoreboard" class="admin-card-link">
            <div class="admin-card">
                <img src="~/images/admin_score_board.png" alt="Scoreboard" />
                <p>Score Board</p>
            </div>
        </a>
        <a asp-controller="Account" asp-action="AdminAboutUs" class="admin-card-link">
            <div class="admin-card">
                <img src="~/images/admin_about_us.png" alt="About Us" />
                <p>About Us</p>
            </div>
        </a>
        <a asp-controller="Admin" asp-action="Notifications" class="admin-card-link">
            <div class="admin-card">
                <img src="~/images/admin_profile.png" alt="Profile" />
                <p>Notification</p>
            </div>
        </a>
    </div>

</div>
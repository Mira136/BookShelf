@model List<BookShelf.Models.ViewModels.ScoreboardViewModel>

@{
    // ViewData["Title"] = "Score-Board";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<title>BookShelf</title>
@section Styles {
    <link rel="stylesheet" href="~/css/scoreboard.css" />
}

<div class="scoreboard-page">

    <!-- BACK BUTTON + TITLE -->
    <div class="sb-page-header">
        <a href="/Admin/Dashboard" class="sb-back-btn">
            <i class="fa fa-arrow-left"></i>
        </a>
        <h2 class="sb-page-title">Score-Board</h2>
    </div>

    <!-- MAIN CARD -->
    <div class="sb-card">

        <!-- SEARCH BAR -->
        <div class="sb-search-wrapper">
            <div class="sb-search-bar">
                <input type="text" placeholder="Search here" id="sbSearch" />
                <i class="fa fa-magnifying-glass"></i>
            </div>
        </div>

        <!-- TABLE -->
        <div class="sb-table">

            <!-- HEADER -->
            <div class="sb-row sb-header-row">
                <div>Sr No.</div>
                <div>Username</div>
                <div>Credits</div>
                <div>Action</div>
                <div>DateTime</div>
            </div>

            <!-- ROWs -->
            @foreach (var item in Model)
            {
                <div class="sb-row">
                    <div>@item.SrNo</div>
                    <div>@item.Username</div>
                    <div><span class="credit pos">@item.Credits</span></div>
                    <div>@item.Action</div>
                    <div class="datetime-cell">
                        <span class="datetime-date">@item.Date</span>
                        <span class="datetime-time">@item.Time</span>
                    </div>
                </div>
            }

        </div>
        <!-- end sb-table -->

    </div>
    <!-- end sb-card -->

</div>

@section Scripts {
    <script>
        document.getElementById('sbSearch').addEventListener('input', function () {
            const query = this.value.toLowerCase();
            document.querySelectorAll('.sb-row:not(.sb-header-row)').forEach(row => {
                row.style.display = row.textContent.toLowerCase().includes(query) ? '' : 'none';
            });
        });
    </script>
}
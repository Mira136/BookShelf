@{
    ViewData["Title"] = "Score-Board";
}
@section Styles {
    <link rel="stylesheet" href="~/css/scoreboard.css" />
}

<div class="scoreboard-page">

    <!-- BACK BUTTON + TITLE -->
    <div class="sb-page-header">
        <a href="/Admin/Dashboard" class="sb-back-btn">
            <i class="fa fa-arrow-left"></i>
        </a>
        <h2 class="sb-page-title">Score-Board</h2>
    </div>

    <!-- MAIN CARD -->
    <div class="sb-card">

        <!-- SEARCH BAR -->
        <div class="sb-search-wrapper">
            <div class="sb-search-bar">
                <input type="text" placeholder="Search here" id="sbSearch" />
                <i class="fa fa-magnifying-glass"></i>
            </div>
        </div>

        <!-- TABLE -->
        <div class="sb-table">

            <!-- HEADER -->
            <div class="sb-row sb-header-row">
                <div>Sr no.</div>
                <div>Username</div>
                <div>Credits</div>
                <div>Action</div>
                <div>DateTime</div>
            </div>

